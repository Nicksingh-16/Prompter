<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/template_panel"
    android:layout_width="match_parent"
    android:layout_height="@dimen/ai_panel_height"
    android:orientation="vertical"
    android:background="@color/bg_secondary"
    android:visibility="gone"
    android:paddingHorizontal="10dp"
    android:paddingTop="8dp">

    <!-- Header: title + category chips -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="\u26A1 Templates"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:scrollbars="none"
            android:paddingStart="8dp">

            <LinearLayout
                android:id="@+id/tmpl_category_chips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical" />

        </HorizontalScrollView>

    </LinearLayout>

    <!-- Template list (scrollable) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fadingEdge="vertical"
        android:fadingEdgeLength="16dp">

        <LinearLayout
            android:id="@+id/tmpl_items_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

    <!-- Template fill area (shown when template selected) -->
    <LinearLayout
        android:id="@+id/tmpl_fill_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="8dp">

        <TextView
            android:id="@+id/tmpl_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:paddingBottom="6dp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="80dp">

            <LinearLayout
                android:id="@+id/tmpl_fields_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </ScrollView>

    </LinearLayout>

    <!-- Bottom buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:gravity="end|center_vertical"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/btn_tmpl_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Close"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:paddingHorizontal="12dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_tmpl_insert"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Insert"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_insert_button"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</LinearLayout>
