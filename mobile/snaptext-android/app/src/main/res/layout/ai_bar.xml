<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ai_bar"
    android:layout_width="match_parent"
    android:layout_height="@dimen/suggestion_bar_height"
    android:orientation="vertical"
    android:background="@color/ai_bar_bg">

    <!-- Tone Guard strip (3dp colored bar at top, hidden by default) -->
    <View
        android:id="@+id/tone_guard_strip"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:visibility="gone" />

    <!-- Main bar content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp">

        <!-- AI trigger button -->
        <TextView
            android:id="@+id/btn_ai_trigger"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:gravity="center"
            android:text="\u2728"
            android:textSize="14sp"
            android:paddingHorizontal="14dp"
            android:background="@drawable/bg_ai_button"
            android:clickable="true"
            android:focusable="true" />

        <!-- Scrollable mode chips (shown on AI trigger tap) -->
        <HorizontalScrollView
            android:id="@+id/mode_scroll"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scrollbars="none"
            android:paddingStart="8dp"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/mode_chips_container"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical" />

        </HorizontalScrollView>

        <!-- Suggestion text (default state) -->
        <TextView
            android:id="@+id/suggestion_text"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:singleLine="true"
            android:text="Tap \u2728 to transform with AI" />

        <!-- Tone Guard emoji (right side, hidden by default) -->
        <TextView
            android:id="@+id/tone_emoji"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="16sp"
            android:paddingHorizontal="6dp"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
