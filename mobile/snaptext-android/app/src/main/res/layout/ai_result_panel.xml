<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ai_result_panel"
    android:layout_width="match_parent"
    android:layout_height="@dimen/ai_panel_height"
    android:orientation="vertical"
    android:background="@color/bg_secondary"
    android:visibility="gone"
    android:paddingHorizontal="14dp"
    android:paddingTop="10dp">

    <!-- Streaming result text -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fadingEdge="vertical"
        android:fadingEdgeLength="20dp">

        <TextView
            android:id="@+id/ai_result_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif"
            android:lineSpacingExtra="5dp" />

    </ScrollView>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="end|center_vertical"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="@string/cancel"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:paddingHorizontal="18dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_copy"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="@string/copy_result"
            android:textColor="@color/accent_blue"
            android:textSize="13sp"
            android:paddingHorizontal="18dp"
            android:layout_marginStart="4dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_insert"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="@string/insert_result"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingHorizontal="22dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_insert_button"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>
</LinearLayout>
